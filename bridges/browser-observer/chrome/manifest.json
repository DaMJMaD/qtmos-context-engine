{
  "manifest_version": 3,
  "name": "QTMoS Browser Observer",
  "version": "0.1.0",
  "description": "Observe active browser state and post web.observe events into QTMoS Alpha.",
  "permissions": [
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "QTMoS Browser Observer"
  }
}
